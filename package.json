{
  "name": "lit-channel",
  "version": "1.3.0",
  "type": "module",
  "main": "./src/lit-channel.js",
  "exports": {
    ".": "./dist/lit-channel.js",
    "./lit-channel.js": "./dist/lit-channel.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint . --fix",
    "start": "web-dev-server --open",
    "prepack": "npm run build",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && rollup -c",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "broadcast-channel": "^7.1.0"
  },
  "peerDependencies": {
    "lit": "^3"
  },
  "devDependencies": {
    "@esm-bundle/chai": "^4.3.4-fix.0",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/mocha": "^10.0.10",
    "@web/dev-server": "^0.4.6",
    "@web/rollup-plugin-import-meta-assets": "^2.3.2",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "eslint": "^10.0.0",
    "playwright": "^1.58.2",
    "ws": "^8.19.0"
  },
  "keywords": [
    "lit",
    "web components",
    "pub-sub",
    "websocket"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dougmoscrop/lit-channel.git"
  },
  "author": "Doug Moscrop <doug.moscrop@gmail.com>",
  "license": "MIT",
  "description": "Lightweight pub-sub over a multiplexed websocket for Lit"
}
